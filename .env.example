# ═══════════════════════════════════════════════════════
#  TaskFlow — Root Environment Variables
#  Copy this file to .env and fill in all values
# ═══════════════════════════════════════════════════════

# ── Docker Postgres ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=taskflow_db

# ── Backend ──────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-random-64-character-string-xxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change-me-to-another-random-64-character-string-xxxxxxxxxxxxxxxxxxxxxxxx

# ── URLs ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
